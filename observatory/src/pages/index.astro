---
import Base from "../layouts/Base.astro";
import Cosmos from "../components/Cosmos.astro";
import Hud from "../components/Hud.astro";
import { Image } from "astro:assets";
import { projects, services, processStages } from "../data/universe.js";
const base = import.meta.env.BASE_URL;

const shots = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/work/*.webp",
  { eager: true },
);
const shotFor = (slug: string) => shots[`../assets/work/${slug}.webp`]?.default;
---

<Base
  title="Sirius Ascent — Digital Architecture Studio, Pretoria"
  description="A living star map of the work we've built. Sirius Ascent designs and builds websites engineered like instruments — for South African businesses that intend to be taken seriously."
>
  <Cosmos />
  <Hud />

  <main id="main">
    <section class="sec" id="hero">
      <p class="hero__eye">A living star map</p>
      <h1 class="hero__title">We design websites<br />engineered like <em>instruments.</em></h1>
      <div class="hero__row">
        <p class="hero__sub">
          This is our universe. <b>Sirius is the studio;</b> every other light is a
          business we built. Follow the star — it will guide you down through the observatory.
        </p>
        <div class="hero__cta">
          <a class="btn btn--p" data-mag href="#portfolio">Enter the sky ↓</a>
          <a class="btn btn--g" data-mag href="#contact">Establish contact</a>
        </div>
      </div>
    </section>

    <section class="sec sec--travel" id="portfolio">
      <div class="head" data-head>
        <p class="eye">The stars · portfolio</p>
        <h2 class="h2">Every project <em>is a star.</em></h2>
        <p class="subl">Scroll to travel the constellation — Sirius reaches out to each project it built, one by one.</p>
        <p class="count mono" id="portfolioCount" aria-hidden="true">01 / 10</p>
      </div>
      <!-- Canvas is decorative; this is the real, accessible route to every case study -->
      <nav class="sr-nav" aria-label="Project case studies">
        <ul>
          {projects.map((p) => (
            <li>
              <a href={`${base}work/${p.slug}`}>
                {p.name} — {p.status === "risen" ? "live site" : "demo"} case study
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </section>

    <!-- ===================== THE DEEP FIELD ===================== -->
    <section class="sec-df" id="deepfield" aria-label="The deep field — discovered work">
      <div class="df-intro">
        <p class="eye">The deep field</p>
        <h2 class="h2">The work, <em>resolving.</em></h2>
        <p class="subl">Beyond the constellation, each system's light finally reaches the observatory. Keep descending — approach a system and it comes into focus.</p>
        <p class="df-cue mono" aria-hidden="true">Incoming signal ↓</p>
      </div>

      {projects.map((p, i) => {
        const shot = shotFor(p.slug);
        const sys = String(i + 1).padStart(2, "0");
        return (
          <article class="df-field" style={`--accent:${p.accent};--tempo:${p.tempo}s`}>
            <div class="df-atmos" aria-hidden="true">
              <span class="df-nebula"></span>
              <span class="df-particles">
                {Array.from({ length: 14 }).map(() => <i></i>)}
              </span>
            </div>
            <div class="df-window" style="--resolve:0">
              {shot && (
                <Image
                  class="df-shot"
                  src={shot}
                  alt={`The ${p.name} website, resolving into focus`}
                  widths={[480, 800, 1200, 1600]}
                  sizes="(max-width: 900px) 100vw, 860px"
                  loading="lazy"
                />
              )}
              <span class="df-grain" aria-hidden="true"></span>
              <span class="df-scan" aria-hidden="true"></span>
              <span class="df-rings" aria-hidden="true"><i></i><i></i><i></i></span>
              <span class="df-reticle" aria-hidden="true"></span>
            </div>
            <div class="df-tele">
              <p class="df-class mono">{p.system}</p>
              <p class="df-sys mono">System {sys} <span class="df-slash">//</span> <span data-df-decode>{p.name}</span></p>
              <p class="df-meta mono">
                <span class={`df-status df-status--${p.status}`}>{p.status === "risen" ? "Risen" : "Plotted"}</span>
                <span class="df-dot" aria-hidden="true">·</span> {p.industry}
                <span class="df-dot" aria-hidden="true">·</span> mag {p.magnitude}
              </p>
              <a class="df-enter" href={`${base}work/${p.slug}`}>Enter the system →</a>
            </div>
          </article>
        );
      })}
    </section>

    <section class="sec" id="services">
      <div class="head" data-head>
        <p class="eye">Galaxies · services</p>
        <h2 class="h2">What we <em>set in orbit.</em></h2>
        <p class="subl">Each capability circles the studio. <b>Hover a body</b> to name it.</p>
        <ul class="sr-only">
          {services.map((s) => <li>{s}</li>)}
        </ul>
      </div>
    </section>

    <section class="sec" id="process">
      <div class="head" data-head>
        <p class="eye">Orbital paths · process</p>
        <h2 class="h2">How the work <em>comes into orbit.</em></h2>
        <p class="subl">Five ordered passes, from first contact to long-term care.</p>
        <ol class="sr-only">
          {processStages.map((s) => <li>{s}</li>)}
        </ol>
      </div>
    </section>

    <section class="sec" id="contact">
      <div class="head" data-head>
        <p class="eye">Establish communication · contact</p>
        <h2 class="h2">Open a <em>channel.</em></h2>
      </div>

      <div class="tx" id="tx" data-head>
        <!-- dormant beacon -->
        <button type="button" class="tx__activate" data-tx-activate aria-expanded="false" aria-controls="txPanel">
          <span class="tx__beacon" aria-hidden="true"><i></i><i></i><i></i></span>
          <span class="tx__activate-label">Activate the beacon</span>
          <span class="tx__activate-sub mono">Begin transmission to Sirius Ascent</span>
        </button>

        <!-- transmission sequence -->
        <form class="tx__panel" id="txPanel" novalidate hidden>
          <div class="tx__head">
            <span class="tx__signal" aria-hidden="true"><i></i><i></i><i></i><i></i></span>
            <span class="tx__status mono" data-tx-status>Channel open</span>
          </div>

          <div class="tx__log" data-tx-log aria-live="polite"></div>

          <div class="tx__stage" data-tx-stage>
            <label class="tx__prompt" for="txInput" data-tx-prompt>My name is…</label>
            <div class="tx__row">
              <input class="tx__input" id="txInput" data-tx-input autocomplete="name" enterkeyhint="send" />
              <button class="tx__go" type="submit" aria-label="Transmit this signal">↵</button>
            </div>
            <p class="tx__hint mono">Press Enter to transmit</p>
            <p class="tx__error mono" data-tx-error role="alert" hidden>The channel needs this to continue.</p>
          </div>

          <div class="tx__ready" data-tx-ready hidden>
            <p class="tx__ready-label mono">✦ Transmission ready</p>
            <button class="btn btn--p tx__send" type="submit" data-mag>Send signal →</button>
          </div>

          <div class="tx__done" data-tx-done hidden>
            <span class="tx__done-star" aria-hidden="true"></span>
            <p class="tx__done-t">Transmission received.</p>
            <p class="tx__done-b">Your signal has been logged by Sirius Ascent. We'll respond shortly and begin plotting your journey.</p>
          </div>
        </form>
      </div>
    </section>
  </main>
</Base>

<script>
  import { initBeacon } from "../scripts/beacon.js";
  import { initDeepField } from "../scripts/deepfield.js";
  const run = () => { initBeacon(); initDeepField(); };
  if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", run);
  else run();
</script>
