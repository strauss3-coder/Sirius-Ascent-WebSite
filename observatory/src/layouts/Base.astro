---
import "../styles/global.css";

export interface Props {
  title: string;
  description: string;
  /** Absolute or root-relative OG image path */
  image?: string;
  /** Overrides the <html> theme; the site is a committed night sky */
  noindex?: boolean;
}

const {
  title,
  description,
  image = "/og/observatory.png",
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;

const org = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: "Sirius Ascent",
  description:
    "Digital architecture studio in Pretoria — websites engineered like instruments.",
  url: Astro.site?.href,
  areaServed: "South Africa",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Pretoria",
    addressCountry: "ZA",
  },
  sameAs: ["https://instagram.com/sirius_ascent_"],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#08090c" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sirius Ascent" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_ZA" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Brand type: Sora (display/sans), Cormorant Garamond (serif), JetBrains Mono (telemetry) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500;1,600&family=Inter:wght@300;400;500&family=JetBrains+Mono:wght@400;500&family=Sora:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(org)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <slot />
  </body>
</html>
