---
// The persistent universe layer: the star field canvas, the custom cursor,
// and the boot telemetry. The engine drives everything from here.
---

<canvas id="cosmos" aria-hidden="true"></canvas>
<div class="cur-ring" aria-hidden="true"></div>
<div class="cur-dot" aria-hidden="true"></div>
<div class="boot" aria-live="polite"><span id="bootText">CALIBRATING SKY</span></div>

<script>
  import { initObservatory } from "../scripts/observatory.js";
  const base = import.meta.env.BASE_URL;
  const run = () => initObservatory({ base });
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", run);
  } else {
    run();
  }
</script>
